# Enable all Presidio features for testing
CONFIG_PRESIDIO_SECURITY_ENABLE=y
CONFIG_PRESIDIO_TLS_HARDENING=y
CONFIG_PRESIDIO_NVS_REDACTION=y
CONFIG_PRESIDIO_NVS_ENCRYPTION=y
CONFIG_PRESIDIO_BOOT_ENFORCEMENT=y
CONFIG_PRESIDIO_ANOMALY_DETECTION=y
CONFIG_PRESIDIO_INPUT_SANITIZATION=y
CONFIG_PRESIDIO_SECURITY_LOG=y
CONFIG_PRESIDIO_LOG_MAX_EVENTS=64

# Partition table with NVS
CONFIG_PARTITION_TABLE_SINGLE_APP=y

# mbedTLS settings for testing
CONFIG_MBEDTLS_SSL_PROTO_TLS1_2=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE=y
CONFIG_MBEDTLS_AES_C=y
CONFIG_MBEDTLS_GCM_C=y
